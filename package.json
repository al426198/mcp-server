{
  "name": "@laberit/mcp-al-codegen",
  "version": "1.0.0",
  "description": "Servidor MCP para la generación de código AL",
  "type": "module",
  "bin": {
    "al_codegen": "build/index.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "genkey": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "show": "npm run build && npx @modelcontextprotocol/inspector node ./build/index.js MCP_PROXY_AUTH_TOKEN=$(npm run genkey)",
    "build": "tsc",
    "docs": "typedoc src/docs-index.ts"
  },
  "files": [
    "build",
    "src/templates"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "handlebars": "^4.7.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typedoc": "^0.28.19",
    "typedoc-material-theme": "^1.4.1",
    "typescript": "^6.0.2"
  }
}