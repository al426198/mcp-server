page {{id}} "{{name}}"
{
    {{#if properties}}
    {{#each properties}}
    {{@key}} = {{{this}}};
    {{/each}}

    {{/if}}
    layout
    {
        {{> (lookup properties "PageType")}}
    }
    {{#if actions}}

    actions
    {
        {{#each areas}}
        {{> area}}
        {{/each}}
    }
    {{/if}}
}