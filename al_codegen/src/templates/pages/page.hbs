page {{id}} "{{name}}"
{
    {{#each properties}}
    {{#if (eq @key "PageType")}}
    {{@key}} = \"{{this}}\";
    {{else}}
    {{@key}} = {{this}};
    {{/if}}
    {{/each}}

    layout
    {
        {{> (lookup properties "PageType")}}
    }
    {{#if actions}}

    actions
    {
        {{#each areas}}
        {{> area}}
        {{/each}}
    }
    {{/if}}
}