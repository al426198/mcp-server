pageextension {{id}} "{{name}}" extends "{{target}}"
{
    layout
    {
        {{#each controls}}
        {{operation}}("{{anchor}}")
        {
            {{> control}}
        }
        {{/each}}
    }
    {{#if actions}}

    actions
    {
        {{#each areas}}
        {{> area}}
        {{/each}}
    }
    {{/if}}
}
