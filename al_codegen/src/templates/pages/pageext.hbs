pageextension {{id}} "{{name}}" extends "{{target}}"
{
    {{#if properties}}
    {{#each properties}}
    {{@key}} = {{{this}}};
    {{/each}}

    {{/if}}
    {{#if layoutChanges}}
    layout
    {
        {{#each layoutChanges}}
        {{#if control}}
        {{operation}}("{{anchor}}"; "{{control}}")
        {{else}}
        {{operation}}("{{anchor}}")
        {
            {{#each controls}}
            {{> (lookup this "type")}}
            {{/each}}
            {{#each properties}}
            {{@key}} = {{{this}}};
            {{/each}}
        }
        {{/if}}
        {{/each}}
    }
    {{/if}}
    {{#if actionChanges}}

    actions
    {
        {{#each actionChanges}}
        {{#if control}}
        {{operation}}("{{anchor}}"; "{{control}}")
        {{else}}
        {{operation}}("{{anchor}}")
        {
            {{#each controls}}
            {{#if groups}}
            {{> action-group}}
            {{else}}
            {{> action}}
            {{/if}}
            {{/each}}
            {{#each properties}}
            {{@key}} = {{{this}}};
            {{/each}}
        }
        {{/if}}
        {{/each}}
    }
    {{/if}}
}
