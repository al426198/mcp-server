page {{id}} "{{name}}"
{
    {{#each properties}}
    {{@key}} = {{this}};
    {{/each}}

    layout
    {
        area(Content)
        {
            {{> repeater}}
        }
        area(FactBoxes)
        {
            {{#each parts}}
                {{> part}}
            {{/each}}
        }
    }
    {{#if actions}}
    
    actions
    {
        area(Processing)
        {
            {{#each actions}}
            action("{{name}}")
            {
                {{#each properties}}
                {{@key}} = {{this}};
                {{/each}}

                trigger OnAction()
                begin
                    
                end;
            }
            {{/each}}
        }
    }
    {{/if}}
}
