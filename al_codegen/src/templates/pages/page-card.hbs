page {{id}} "{{name}}"
{
    {{#each properties}}
    {{@key}} = {{this}};
    {{/each}}

    layout
    {
        area(Content)
        {
            {{#each groups}}
            group("{{name}}")
            {
                {{#each properties}}
                {{@key}} = {{this}};
                {{/each}}

                {{#each fields}}
                field("{{name}}"; Rec."{{sourceField}}")
                {
                    {{#each properties}}
                    {{@key}} = {{this}};
                    {{/each}}
                }
                {{/each}}
            }
            {{/each}}
        }
        area(FactBoxes)
        {
            {{#if parts}}
                {{#each parts}}
                part("{{name}}"; "{{source}}")
                {
                    {{#each properties}}
                    {{@key}} = {{this}};
                    {{/each}}
                }
                {{/each}}
            {{/if}}
        }
    }

    {{#if actions}}
    actions
    {
        area(Processing)
        {
            {{#each actions}}
            action("{{name}}")
            {
                {{#each properties}}
                {{@key}} = {{this}};
                {{/each}}

                trigger OnAction()
                begin
                    
                end;
            }
            {{/each}}
        }
    }
    {{/if}}
}
