page {{id}} "{{name}}"
{
    {{#each properties}}
    {{@key}} = {{this}};
    {{/each}}

    layout
    {
        {{#if groups}}
        area(Content)
        {
            {{#each groups}}
            {{> group}}
            {{/each}}
        }
        {{/if}}
        {{#if parts}}
        area(FactBoxes)
        {
            {{#each parts}}
            part("{{name}}"; "{{source}}")
            {
                {{#each properties}}
                {{@key}} = {{this}};
                {{/each}}
            }
            {{/each}}
        }
        {{/if}}
    }
    {{#if actions}}
    
    actions
    {
        area(Processing)
        {
            {{#each actions}}
            action("{{name}}")
            {
                {{#each properties}}
                {{@key}} = {{this}};
                {{/each}}

                trigger OnAction()
                begin
                    
                end;
            }
            {{/each}}
        }
    }
    {{/if}}
}
