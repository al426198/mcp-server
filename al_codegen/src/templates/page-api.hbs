page {{id}} "{{name}}"
{
    {{#each properties}}
    {{@key}} = {{this}};
    {{/each}}

    layout
    {
        area(Content)
        {
            {{#if repeater}}
            repeater("{{repeater.name}}")
            {
                {{#each repeater.properties}}
                {{@key}} = {{this}};
                {{/each}}

                {{#each repeater.fields}}
                field("{{name}}"; Rec."{{sourceField}}")
                {
                    {{#each properties}}
                    {{@key}} = {{this}};
                    {{/each}}
                }
                {{/each}}
            }
            {{/if}}
        }
    }
}
