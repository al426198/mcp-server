table {{id}} "{{name}}"
{
    {{#each properties}}
    {{@key}} = {{this}};
    {{/each}}

    fields
    {
        {{#each fields}}
        field({{id}}; "{{name}}"; {{type}}{{#if length}}[{{length}}]{{/if}})
        {
            {{#each properties}}
            {{@key}} = {{this}};
            {{/each}}
        }
        {{/each}}
    }
    
    {{#if keys}}
    keys
    {
        {{#each keys}}
        key({{name}}; {{#each fieldNames}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}})
        {
            {{#if clustered}}
            Clustered = true;
            {{/if}}
        }
        {{/each}}
    }
    {{/if}}
    {{#if fieldGroups}}
    fieldgroups 
    {
        {{#each fieldGroups}}
        fieldgroup({{type}}; {{#each fieldNames}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}})
        {
        }
        {{/each}}
    }
    {{/if}}

    trigger OnInsert()
    begin

    end;

    trigger OnModify()
    begin

    end;

    trigger OnDelete()
    begin

    end;

    trigger OnRename()
    begin

    end;
}