tableextension {{id}} "{{name}}" extends "{{target}}"
{
    {{#if properties}}
    {{#each properties}}
    {{@key}} = {{this}};
    {{/each}}

    {{/if}}
    {{#if fields}}
    fields
    {
        {{#each fields}}
        {{> table:field}}
        {{/each}}
    }
    {{/if}}
    {{#if keys}}
    
    keys
    {
        {{#each keys}}
        {{> key}}
        {{/each}}
    }
    {{/if}}
    {{#if fieldGroups}}

    fieldgroups 
    {
        {{#each fieldGroups}}
        {{> fieldgroup add=true}}
        {{/each}}
    }
    {{/if}}
}