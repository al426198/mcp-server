tableextension {{id}} "{{name}}" extends "{{target}}"
{
    {{#each properties}}
    {{@key}} = {{this}};
    {{/each}}
    {{#if showFields}}
    fields
    {
        {{#each fields}}
        field({{id}}; "{{name}}"; {{type}}{{#if length}}[{{length}}]{{/if}})
        {
            {{#each properties}}
            {{@key}} = {{this}};
            {{/each}}
        }
        {{/each}}

        {{#each modifyFields}}
        modify("{{name}}")
        {
            {{#each properties}}
            {{@key}} = {{this}};
            {{/each}}
        }
        {{/each}}
    }
    {{/if}}
    {{#if keys}}
    keys
    {
        {{#each keys}}
        key("{{name}}"; {{#each fieldNames}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}})
        {
            {{#if clustered}}
            Clustered = true;
            {{/if}}
        }
        {{/each}}
    }
    {{/if}}
    {{#if fieldGroups}}
    fieldgroups 
    {
        {{#each fieldGroups}}
        addlast({{type}}; {{#each fieldNames}}"{{this}}"{{#unless @last}}, {{/unless}}{{/each}})
        {
        }
        {{/each}}
    }
    {{/if}}
}